---
import BasicLayout from "../layouts/BasicLayout.astro";
import { WEBSITE_PROJECTS } from "../lib/websites";
---

<script>
  import { timeline, type TimelineDefinition } from "motion";
  import { loaderAnimation } from "../lib/constants";

  const sequence = [
    loaderAnimation,
    [
      ".website-card",
      { opacity: [0, 1], y: [24, 0], scale: [0.98, 1] },
      { at: "-0.2", duration: 0.45, delay: 0.08 },
    ],
  ];

  timeline(sequence as TimelineDefinition);
</script>

<BasicLayout
  title="Jerold Arranzado - Websites"
  description="A curated selection of websites and UI work, with visual highlights and project details."
  page="websites"
>
  <main class="w-full max-w-6xl mx-auto px-4 py-7 md:px-6 md:py-8 text-app-fg">
    <a
      href="/"
      class="inline-flex text-sm bg-app-card hover:opacity-85 mb-6 px-4 py-2 border border-solid border-app-border rounded-lg"
      >Back</a
    >

    <header class="mb-6">
      <p class="text-xs uppercase tracking-[0.2em] text-app-muted">Selected Work</p>
      <h1 class="text-3xl sm:text-4xl font-bold mt-2">Websites</h1>
      <p class="text-app-muted mt-2 max-w-2xl">
        A visual collection of projects with emphasis on clean UI, image-forward
        presentation, and practical UX decisions.
      </p>
    </header>

    <section class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 items-start">
      {
        WEBSITE_PROJECTS.map((website) => (
          <article class="website-card group flex h-full flex-col rounded-xl border border-app-border bg-app-card overflow-hidden shadow-lg transition duration-300 hover:-translate-y-1 hover:border-primary-500 hover:shadow-primary-500/10">
            <div class="relative overflow-hidden">
              {website.featured && (
                <span class="absolute top-3 left-3 z-10 rounded-full bg-primary-500 text-black text-xs font-bold px-3 py-1">
                  Highlight
                </span>
              )}
              <img
                src={website.image}
                alt={`${website.title} preview`}
                class="h-40 w-full object-cover transition duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>

            <div class="flex flex-1 flex-col p-3.5">
              <h2 class="text-lg font-semibold leading-snug line-clamp-2">{website.title}</h2>
              <p class="text-sm text-app-muted mt-1.5 leading-relaxed line-clamp-3 min-h-[4.5rem]">
                {website.description}
              </p>

              <ul class="flex flex-wrap gap-1.5 mt-3">
                {website.tags.slice(0, 6).map((tag) => (
                  <li class="text-xs rounded-full border border-app-border px-2.5 py-1 text-app-muted">
                    {tag}
                  </li>
                ))}
                {website.tags.length > 6 && (
                  <li class="relative group/others text-xs rounded-full border border-app-border px-2.5 py-1 text-app-muted cursor-help">
                    {website.tags.length - 6} others
                    <span class="pointer-events-none absolute left-0 top-full z-20 mt-1 hidden w-52 max-w-[16rem] whitespace-normal break-words rounded-md border border-app-border bg-app-card px-2 py-1.5 text-xs text-app-fg shadow-lg group-hover/others:block">
                      {website.tags.slice(6).join(", ")}
                    </span>
                  </li>
                )}
              </ul>

              <div class="grid grid-cols-2 gap-2 pt-3 mt-auto">
                {website.codeUrl ? (
                  <a
                    href={website.codeUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex items-center justify-center gap-1.5 rounded-md border border-red-500 px-3 py-2 text-sm font-semibold text-red-300 bg-red-500/10 transition hover:bg-red-500/20"
                  >
                    Code
                  </a>
                ) : (
                  <button
                    type="button"
                    disabled
                    aria-label="Code unavailable"
                    class="inline-flex items-center justify-center gap-1.5 rounded-md border border-red-500 px-3 py-2 text-sm font-semibold text-red-300 bg-red-500/5 cursor-not-allowed"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      class="h-4 w-4"
                      aria-hidden="true"
                    >
                      <rect x="4.5" y="10.5" width="15" height="9" rx="2" />
                      <path d="M8 10.5V8a4 4 0 0 1 8 0v2.5" />
                    </svg>
                    Code
                  </button>
                )}

                {website.siteUrl ? (
                  <a
                    href={website.siteUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex items-center justify-center gap-1.5 rounded-md border border-green-500 px-3 py-2 text-sm font-semibold text-green-300 bg-green-500/10 transition hover:bg-green-500/20"
                  >
                    Site
                  </a>
                ) : (
                  <button
                    type="button"
                    disabled
                    aria-label="Site unavailable"
                    class="inline-flex items-center justify-center gap-1.5 rounded-md border border-green-500 px-3 py-2 text-sm font-semibold text-green-300 bg-green-500/5 cursor-not-allowed"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      class="h-4 w-4"
                      aria-hidden="true"
                    >
                      <rect x="4.5" y="10.5" width="15" height="9" rx="2" />
                      <path d="M8 10.5V8a4 4 0 0 1 8 0v2.5" />
                    </svg>
                    Site
                  </button>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>
</BasicLayout>
