---
import Card from "./Card/index.astro";
import Button from "./Button.astro";
import { LINKS } from "../lib/constants";
import { Icon } from "astro-icon/components";
import Tooltip from "./Tooltip/index";
import { Image } from "astro:assets";
---

<Card colSpan="md:col-span-3" rowSpan="md:row-span-3">
  <div class="flex w-full h-full items-start gap-3 md:gap-5">
    <div class="flex flex-col gap-3 md:max-h-[280px]">
      <div class="flex flex-col gap-2">
        <h6 class="text-sm font-light m-0 text-gray-500">Welcome!</h6>
        <p class="m-0 font-light text-lg leading-relaxed md:text-xl">
          Hi, I'm <b class="font-bold">Jerold Arranzado</b>, a full stack developer
          based in Cebu City. I build practical web apps, APIs, and business-focused
          systems with clean, maintainable code.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 md:gap-3">
        <a href={LINKS.github} aria-label="github profile" target="_blank">
          <Button aria-label="github profile">
            <Icon name="ri:github-fill" class="h-6" />
            <span class="sr-only">GitHub Profile</span>
          </Button>
        </a>
        <a href={LINKS.linkedin} aria-label="linkedin profile" target="_blank">
          <Button aria-label="linkedin profile">
            <Icon name="ri:linkedin-box-fill" class="h-6" />
            <span class="sr-only">Linkedin Profile</span>
          </Button>
        </a>
        <a href={LINKS.facebook} aria-label="facebook profile" target="_blank">
          <Button aria-label="facebook profile">
            <Icon name="ri:facebook-fill" class="h-6" />
            <span class="sr-only">Facebook Profile</span>
          </Button>
        </a>
        <Tooltip client:visible>
          <Button aria-label="easter egg btn">
            <Icon name="ri:emotion-laugh-line" class="h-6" />
            <span class="sr-only">Easter egg button</span>
          </Button>
        </Tooltip>
      </div>
    </div>
    <Image
      width="300"
      height="300"
      src="/me.webp"
      class="w-auto max-h-[230px] md:max-h-[260px] select-none absolute right-[-96px] bottom-[-12px] z-[-1] opacity-45 md:opacity-100 md:relative md:right-auto md:bottom-auto md:z-auto pointer-events-none"
      alt="memoji of jerold"
    />
  </div>
</Card>
