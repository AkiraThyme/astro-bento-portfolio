---
import Card from "./Card/index.astro";
import { LINKS } from "../lib/constants";
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-3">
  <div class="h-full">
    <header class="flex items-center">
      <h1 class="text-white text-xl font-bold">Let's start working together!</h1>
    </header>
    <address class="flex flex-col mt-4 not-italic">
      <h2 class="text-gray-500">Contact Details</h2>
      <p>0991-297-2644</p>
      <p>jerold.arranzado30@gmail.com</p>
      <p>Cebu City, Philippines</p>
    </address>
    <div class="flex flex-col mt-4 w-fit">
      <h2 class="text-gray-500">Socials</h2>
      <ul>
        <li>
          <a href={LINKS.linkedin} target="_blank">LinkedIn</a>
        </li>
        <li>
          <a href={LINKS.github} target="_blank">GitHub</a>
        </li>
        <li>
          <a href={LINKS.facebook} target="_blank">Facebook</a>
        </li>
        <li>
          <a href={LINKS.discord} target="_blank">Discord</a>
        </li>
      </ul>
    </div>
  </div>
</Card>
